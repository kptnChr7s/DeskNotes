<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <Color x:Key="Color.Canvas">#090B0F</Color>
    <Color x:Key="Color.Surface1">#11141B</Color>
    <Color x:Key="Color.Surface2">#171B24</Color>
    <Color x:Key="Color.Surface3">#1E2430</Color>
    <Color x:Key="Color.SurfaceHover">#252C3A</Color>
    <Color x:Key="Color.Border">#2A3140</Color>
    <Color x:Key="Color.BorderSubtle">#1A2030</Color>

    <!-- Text -->
    <Color x:Key="Color.TextPrimary">#EEF1F8</Color>
    <Color x:Key="Color.TextSecondary">#8D96AB</Color>
    <Color x:Key="Color.TextMuted">#5A6478</Color>

    <!-- Brand -->
    <Color x:Key="Color.Accent">#7C6AF7</Color>
    <Color x:Key="Color.AccentSoft">#2A2548</Color>
    <Color x:Key="Color.BrandGold">#E8B84A</Color>
    <Color x:Key="Color.BrandGoldSoft">#3A3020</Color>
    <Color x:Key="Color.Success">#3DD68C</Color>
    <Color x:Key="Color.Danger">#F07178</Color>

    <SolidColorBrush x:Key="BackgroundPrimary" Color="{StaticResource Color.Canvas}"/>
    <SolidColorBrush x:Key="BackgroundSecondary" Color="{StaticResource Color.Surface1}"/>
    <SolidColorBrush x:Key="BackgroundElevated" Color="{StaticResource Color.Surface3}"/>

    <SolidColorBrush x:Key="CardBackground" Color="{StaticResource Color.Surface2}"/>
    <SolidColorBrush x:Key="CardBackgroundHover" Color="{StaticResource Color.SurfaceHover}"/>
    <SolidColorBrush x:Key="CardBorder" Color="{StaticResource Color.Border}"/>
    <SolidColorBrush x:Key="BorderSubtle" Color="{StaticResource Color.BorderSubtle}"/>

    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource Color.TextSecondary}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource Color.TextMuted}"/>

    <SolidColorBrush x:Key="AccentBlue" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="AccentSoft" Color="{StaticResource Color.AccentSoft}"/>
    <SolidColorBrush x:Key="AccentYellow" Color="{StaticResource Color.BrandGold}"/>
    <SolidColorBrush x:Key="BrandGoldSoft" Color="{StaticResource Color.BrandGoldSoft}"/>
    <SolidColorBrush x:Key="DangerRed" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="SuccessGreen" Color="{StaticResource Color.Success}"/>

    <SolidColorBrush x:Key="FilterChipBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="FilterChipActive" Color="{StaticResource Color.Surface3}"/>

    <!-- Gradients -->
    <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#10131A" Offset="0"/>
        <GradientStop Color="#090B0F" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderGlowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A2030" Offset="0"/>
        <GradientStop Color="#11141B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#8B7CF8" Offset="0"/>
        <GradientStop Color="#6D5CE8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ComposerBorderBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3A3558" Offset="0"/>
        <GradientStop Color="#2A3140" Offset="0.5"/>
        <GradientStop Color="#3A3020" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>