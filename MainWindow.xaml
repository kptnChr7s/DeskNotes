<Window
    x:Class="DeskNotes.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:helpers="clr-namespace:DeskNotes.Helpers"
    xmlns:converters="clr-namespace:DeskNotes.Converters"
    xmlns:controls="clr-namespace:DeskNotes.Controls"
    xmlns:models="clr-namespace:DeskNotes.Models"

    Title="DeskNotes"
    Width="440"
    Height="660"
    MinWidth="380"
    MinHeight="500"
    FontFamily="Segoe UI"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType">

    <Border x:Name="MainBorder" Style="{StaticResource ShellBorder}" Effect="{StaticResource ShellDropShadow}">

        <Grid x:Name="DiscoRoot">
            <Grid x:Name="DiscoContentRoot" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="DiscoScale" ScaleX="1" ScaleY="1"/>
                        <RotateTransform x:Name="DiscoRotate" Angle="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>

        <Grid>
            <Grid.Resources>
                <helpers:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter"/>
                <helpers:ZeroToHiddenConverter x:Key="ZeroToHiddenConverter"/>
                <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
                <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
                <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
                <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border x:Name="HeaderBorder" Grid.Row="0"
                    Background="{StaticResource HeaderGlowBrush}"
                    CornerRadius="20,20,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Padding="22,20,18,18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource AppIconBadgeBrand}" Margin="0,0,14,0">
                                <Image Source="/Assets/desknote-gelb.png"
                                       Width="24" Height="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="AppTitleText" Text="DeskNotes" Style="{StaticResource Text.Title}"/>
                                <TextBlock x:Name="AppSubtitleText" Text="Desktop Notizen" Style="{StaticResource Text.Subtitle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button Margin="0,0,6,0" Click="Pin_Click" ToolTip="Immer im Vordergrund">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource HeaderIconButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Topmost, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BrandGoldSoft}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentYellow}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                                <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                            </ui:Button>

                            <ui:Button Style="{StaticResource HeaderIconButton}" Margin="0,0,6,0"
                                       Click="Settings_Click" ToolTip="Einstellungen">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                            </ui:Button>

                            <ui:Button Style="{StaticResource HeaderIconButton}"
                                       Click="Close_Click" ToolTip="Minimieren">
                                <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                            </ui:Button>
                        </StackPanel>
                    </Grid>

                    <!-- Stats -->
                    <StackPanel x:Name="StatsPillPanel" Grid.Row="1" Orientation="Horizontal" Margin="56,14,0,0">
                        <Border Style="{StaticResource StatPillBorder}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBlue}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                                    <Run Text="{Binding ActiveCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    <Run Text=" offen"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatPillBorder}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessGreen}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                                    <Run Text="{Binding CompletedCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    <Run Text=" erledigt"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <ContentPresenter x:Name="AddonTimerFlyoutHost" Grid.Row="2" Margin="56,8,18,0"/>
                </Grid>
            </Border>

            <!-- Divider -->
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="{StaticResource BorderSubtle}" Margin="20,0"/>

            <!-- Filter bar -->
            <Grid Grid.Row="1" Margin="20,16,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="FilterBarBorder"
                        Background="{StaticResource BackgroundSecondary}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="11"
                        Padding="4">
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Alle"
                                   Command="{Binding ChangeFilterCommand}"
                                   CommandParameter="{x:Static models:TaskFilter.All}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource FilterChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentFilter}" Value="{x:Static models:TaskFilter.All}">
                                            <Setter Property="Background" Value="{StaticResource FilterChipActive}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>

                        <ui:Button Content="Offen"
                                   Command="{Binding ChangeFilterCommand}"
                                   CommandParameter="{x:Static models:TaskFilter.Active}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource FilterChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentFilter}" Value="{x:Static models:TaskFilter.Active}">
                                            <Setter Property="Background" Value="{StaticResource FilterChipActive}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>

                        <ui:Button Content="Erledigt"
                                   Command="{Binding ChangeFilterCommand}"
                                   CommandParameter="{x:Static models:TaskFilter.Completed}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource FilterChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentFilter}" Value="{x:Static models:TaskFilter.Completed}">
                                            <Setter Property="Background" Value="{StaticResource FilterChipActive}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </StackPanel>
                </Border>

                <ui:Button Grid.Column="1"
                           Style="{StaticResource GhostActionButton}"
                           Margin="10,0,0,0"
                           Command="{Binding ClearCompletedCommand}"
                           ToolTip="Erledigte Notizen entfernen"
                           Visibility="{Binding CompletedCount, Converter={StaticResource ZeroToHiddenConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Aufräumen" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
            </Grid>

            <!-- Notes -->
            <Grid Grid.Row="2" Margin="18,14,14,10">

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="72" Height="72" CornerRadius="36"
                            Background="{StaticResource AccentSoft}"
                            BorderBrush="{StaticResource AccentBorder}"
                            BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,18">
                        <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="28" Foreground="{StaticResource AccentBlue}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Keine Notizen hier"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Neue Notiz eingeben oder Strg + Alt + Leertaste"
                               Style="{StaticResource Text.Subtitle}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="24,8,24,0" MaxWidth="300"/>
                </StackPanel>

                <ListBox x:Name="todoList"
                         Background="Transparent"
                         BorderThickness="0"
                         AllowDrop="True"
                         ItemsSource="{Binding FilteredTodos}"
                         SelectedItem="{Binding SelectedTodo}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Visibility="{Binding IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                         Drop="TodoList_Drop"
                         DragOver="TodoList_DragOver">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource NoteCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="18"
                                            Margin="0,2,6,0"
                                            VerticalAlignment="Stretch"
                                            Background="Transparent"
                                            Cursor="SizeAll"
                                            ToolTip="Ziehen zum Sortieren"
                                            PreviewMouseLeftButtonDown="NoteDragHandle_PreviewMouseDown"
                                            PreviewMouseMove="NoteDragHandle_PreviewMouseMove">
                                        <TextBlock Text="&#xE700;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.55"/>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Margin="0,3,14,3"
                                            CornerRadius="3"
                                            Background="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}"
                                            MouseLeftButtonDown="AccentStrip_Click"
                                            Cursor="Hand"
                                            ToolTip="Farbe wechseln"/>

                                    <CheckBox Grid.Column="2"
                                              Style="{StaticResource NoteCheckBox}"
                                              Margin="0,0,14,0"
                                              IsChecked="{Binding IsCompleted, Mode=TwoWay}"/>

                                    <StackPanel Grid.Column="3"
                                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <StackPanel.InputBindings>
                                            <MouseBinding MouseAction="LeftDoubleClick"
                                                          Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}"/>
                                        </StackPanel.InputBindings>

                                        <controls:MarkdownTextBlock Source="{Binding Text}"
                                                                    FontSize="14.5"
                                                                    FontWeight="Medium"
                                                                    LineHeight="22"
                                                                    Foreground="{StaticResource TextPrimary}">
                                            <controls:MarkdownTextBlock.Style>
                                                <Style TargetType="controls:MarkdownTextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </controls:MarkdownTextBlock.Style>
                                        </controls:MarkdownTextBlock>

                                        <TextBlock Margin="0,6,0,0"
                                                   FontFamily="Segoe UI"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding CreatedAt, Converter={StaticResource RelativeTimeConverter}}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Text">
                                                                <Setter.Value>
                                                                    <MultiBinding StringFormat="Erledigt · {0}">
                                                                        <Binding Path="CompletedAt" Converter="{StaticResource RelativeTimeConverter}"/>
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <ui:TextBox Grid.Column="3"
                                                Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                FontSize="14.5"
                                                Background="{StaticResource BackgroundElevated}"
                                                BorderBrush="{StaticResource AccentBlue}"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                KeyDown="TaskTextBox_KeyDown"
                                                Loaded="TaskTextBox_Loaded"
                                                PlaceholderText="Notiz bearbeiten..."/>

                                    <ui:Button Grid.Column="4"
                                               Style="{StaticResource NoteDeleteButton}"
                                               Margin="10,0,0,0"
                                               Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                               CommandParameter="{Binding}"
                                               ToolTip="Löschen (Entf)">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    </ui:Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Composer -->
            <Border x:Name="ComposerOuterBorder" Grid.Row="3" Margin="18,0,18,18" CornerRadius="16" Padding="1"
                    Background="{StaticResource ComposerBorderBrush}">
                <Border CornerRadius="15"
                        Background="{StaticResource BackgroundSecondary}"
                        Padding="6,5,6,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:TextBox x:Name="NewTaskTextBox"
                                    Height="46"
                                    Padding="14,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    PlaceholderText="Neue Notiz hinzufügen..."
                                    Text="{Binding NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                    KeyDown="NewTaskTextBox_KeyDown"
                                    FontSize="14"
                                    Foreground="{StaticResource TextPrimary}"/>

                        <Border Grid.Column="1" CornerRadius="11" Background="{StaticResource AccentGradientBrush}">
                            <ui:Button Width="46" Height="46"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       CornerRadius="11"
                                       Command="{Binding AddTaskCommand}"
                                       ToolTip="Hinzufügen (Enter)">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Foreground="White"/>
                            </ui:Button>
                        </Border>
                    </Grid>
                </Border>
            </Border>

            <!-- Resize -->
            <Thumb Grid.RowSpan="4"
                   Width="24" Height="24"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,6,6"
                   Background="Transparent"
                   Cursor="SizeNWSE"
                   DragDelta="ResizeThumb_DragDelta"
                   Opacity="0.5">
                <Thumb.Template>
                    <ControlTemplate>
                        <Canvas Width="14" Height="14">
                            <Line X1="6" Y1="14" X2="14" Y2="6" Stroke="{StaticResource TextMuted}" StrokeThickness="1.2"/>
                            <Line X1="10" Y1="14" X2="14" Y2="10" Stroke="{StaticResource TextMuted}" StrokeThickness="1.2"/>
                            <Line X1="14" Y1="14" X2="14" Y2="14" Stroke="{StaticResource TextMuted}" StrokeThickness="1.2"/>
                        </Canvas>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>

            </Grid>

            <!-- Disco FX layers -->
            <Canvas x:Name="DiscoFxCanvas"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"
                    ClipToBounds="True"/>

            <Border x:Name="DiscoStrobe"
                    Background="White"
                    Opacity="0"
                    IsHitTestVisible="False"/>

            <Canvas x:Name="DiscoBallCanvas"
                    Width="50" Height="50"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,14,108,0"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="DiscoBallSpin" Angle="0" CenterX="25" CenterY="25"/>
                </Canvas.RenderTransform>
            </Canvas>

            <UniformGrid x:Name="DiscoFloorLights"
                           Rows="1" Columns="12"
                           VerticalAlignment="Bottom"
                           Height="10"
                           Margin="20,0,20,14"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"/>

            <Canvas x:Name="ConfettiFxCanvas"
                    Panel.ZIndex="200"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="False"
                    ClipToBounds="True"/>
        </Grid>
    </Border>
</Window>