<Window x:Class="DeskNotes.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"

        Title="Einstellungen"
        Width="460"
        Height="540"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Border Style="{StaticResource ShellBorder}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource HeaderGlowBrush}"
                    CornerRadius="14"
                    Padding="16,14"
                    Margin="0,0,0,18"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="38" Height="38" CornerRadius="10"
                                Background="{StaticResource AccentSoft}"
                                BorderBrush="#337C6AF7" BorderThickness="1"
                                Margin="0,0,12,0">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="{StaticResource AccentBlue}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Einstellungen" Style="{StaticResource Text.Title}" FontSize="19"/>
                            <TextBlock Text="{Binding Version}" Style="{StaticResource Text.Subtitle}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <ui:Button Grid.Column="1" Style="{StaticResource HeaderIconButton}"
                               Click="Close_Click" ToolTip="Schließen">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </ui:Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="ALLGEMEIN" Style="{StaticResource Text.SectionLabel}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <CheckBox Content="Immer im Vordergrund"
                                      Style="{StaticResource SettingsCheckBox}"
                                      IsChecked="{Binding TopMost, Mode=TwoWay}"/>

                            <CheckBox Content="Mit Windows starten"
                                      Style="{StaticResource SettingsCheckBox}"
                                      Margin="0,0,0,6"
                                      IsEnabled="{Binding AutoStartAvailable}"
                                      IsChecked="{Binding AutoStart, Mode=TwoWay}"/>

                            <TextBlock Text="{Binding AutoStartStatus}"
                                       Style="{StaticResource Text.Caption}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="HOTKEY" Style="{StaticResource Text.SectionLabel}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Background="{StaticResource BackgroundElevated}"
                                    BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14,10">
                                <TextBlock Text="{Binding HotkeyDisplay, Mode=OneWay}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource DangerRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHotkeyActive}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource SuccessGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding HotkeyStatus}"
                                           Style="{StaticResource Text.Caption}"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="TASTENKÜRZEL" Style="{StaticResource Text.SectionLabel}"/>
                    <Border Style="{StaticResource SettingsCard}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource KbdTag}">
                                <TextBlock Text="Enter" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </Border>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Notiz hinzufügen oder speichern"
                                       Style="{StaticResource Text.Subtitle}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource KbdTag}">
                                <TextBlock Text="Entf" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </Border>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Ausgewählte Notiz löschen"
                                       Style="{StaticResource Text.Subtitle}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource KbdTag}">
                                <TextBlock Text="Doppelklick" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </Border>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Notiz bearbeiten"
                                       Style="{StaticResource Text.Subtitle}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource KbdTag}">
                                <TextBlock Text="Esc" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </Border>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Abbrechen oder minimieren"
                                       Style="{StaticResource Text.Subtitle}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="ADDONS" Style="{StaticResource Text.SectionLabel}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <ItemsControl ItemsSource="{Binding LoadedAddons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" FontSize="13.5"
                                                   Foreground="{StaticResource TextPrimary}">
                                            <Run Text="{Binding Name}"/>
                                            <Run Text=" v" Foreground="{StaticResource TextMuted}"/>
                                            <Run Text="{Binding Version}" Foreground="{StaticResource TextMuted}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource Text.Caption}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <StackPanel x:Name="AddonSectionsHost"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,8,0,0">
                <ui:Button HorizontalAlignment="Right"
                           Width="120" Height="40"
                           CornerRadius="10"
                           Background="{StaticResource AccentGradientBrush}"
                           BorderThickness="0"
                           Click="Close_Click">
                    <TextBlock Text="Fertig" FontSize="13.5" FontWeight="SemiBold" Foreground="White"/>
                </ui:Button>
            </Border>
        </Grid>
    </Border>
</Window>